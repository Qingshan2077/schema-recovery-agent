<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.CouponMapper">
  <resultMap id="couponResultMap" type="com.example.model.Coupon">
    <id property="id" column="id"/>
    <result property="couponCode" column="coupon_code"/>
    <collection property="userCoupons" ofType="com.example.model.UserCoupon"
                column="id" select="com.example.mapper.UserCouponMapper.selectByCouponId"/>
    <collection property="orders" ofType="com.example.model.Order"
                column="id" select="com.example.mapper.OrderMapper.selectByCouponId"/>
  </resultMap>
</mapper>
