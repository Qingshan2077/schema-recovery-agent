<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.ReviewMapper">
  <resultMap id="reviewResultMap" type="com.example.model.Review">
    <id property="id" column="id"/>
    <result property="rating" column="rating"/>
    <association property="user" javaType="com.example.model.User"
                 column="user_id" select="com.example.mapper.UserMapper.selectById"/>
    <association property="product" javaType="com.example.model.Product"
                 column="product_id" select="com.example.mapper.ProductMapper.selectById"/>
    <collection property="images" ofType="com.example.model.ReviewImage"
                column="id" select="com.example.mapper.ReviewImageMapper.selectByReviewId"/>
  </resultMap>
</mapper>
