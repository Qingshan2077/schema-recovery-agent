# Database used by local Python scripts
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=schema_recovery_pwd
DB_NAME=schema_recovery_demo

# MySQL container bootstrap
MYSQL_ROOT_PASSWORD=schema_recovery_pwd
MYSQL_DATABASE=schema_recovery_demo
MYSQL_HOST_PORT=3307
MYSQL_CONTAINER_PORT=3306

# API
API_HOST=0.0.0.0
API_PORT=8080

# Runtime paths
DATA_DIR=data
DOCKER_DATA_DIR=/app/data

# LangGraph
LANGGRAPH_ENABLED=true

# Optional LLM judge
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Evidence fusion weights
WEIGHT_CODE=0.40
WEIGHT_ORM=0.25
WEIGHT_COLUMN=0.20
WEIGHT_NAME=0.15
